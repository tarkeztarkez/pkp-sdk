{
  "name": "pkp-sdk-monorepo",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.9",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "bun run --workspaces --sequential build",
    "typecheck": "bun run --workspaces --sequential typecheck",
    "test": "bun run --workspaces --sequential test",
    "cli": "bun run --filter '@pkp-sdk/cli' start",
    "api": "bun run --filter '@pkp-sdk/api' start"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.9.3"
  }
}
