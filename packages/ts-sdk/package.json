{
  "name": "pkp-sdk",
  "version": "0.1.0",
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/ts-sdk/src/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/ts-sdk/src/index.d.ts",
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target node && tsc -p ./tsconfig.build.json",
    "typecheck": "tsc -p ./tsconfig.json",
    "test": "bun test ./src"
  },
  "dependencies": {
    "@pkp-sdk/core": "workspace:*"
  }
}
