{
  "name": "pkp-sdk",
  "version": "0.1.0",
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target node && cp ./src/index.d.ts ./dist/index.d.ts && cp ./src/types.ts ./dist/types.d.ts",
    "typecheck": "tsc -p ./tsconfig.json",
    "test": "bun test ./src"
  }
}
